generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String
  clientEmail String?
  company     String?
  rating      Int
  text        String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  approvedAt  DateTime?

  @@index([status])
}

model Admin {
  id           String @id @default("admin")
  passwordHash String
  embedToken   String @unique
}
